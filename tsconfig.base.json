{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@clinica/domain/*": ["packages/domain/src/*"],
      "@clinica/types/*": ["packages/types/src/*"],
      "@clinica/validation/*": ["packages/validation/src/*"],
      "@clinica/config/*": ["packages/config/src/*"],
      "@clinica/design-tokens/*": ["packages/design-tokens/src/*"]
    }
  }
}
